# ── SERVEUR ──────────────────────────────────
PORT=3000
NODE_ENV=production
# Origines autorisées (séparées par virgule)
ALLOWED_ORIGIN=https://ton-site.com,http://localhost:3000

# ── TWILIO ───────────────────────────────────
# Récupérer sur : console.twilio.com > Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Créer sur : console.twilio.com > Verify > Services > New Service
# Nom suggéré : "Pure Motion CI"
TWILIO_VERIFY_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── SÉCURITÉ ADMIN ───────────────────────────
# Token secret pour les routes admin
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=ton_token_admin_tres_secret_ici

# ── ADMIN PRINCIPAL ───────────────────────────
ADMIN_PASSWORD=PureMotionAdmin2026!
ADMIN_PHONE=+22507058281
